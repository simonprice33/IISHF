{
  "$schema": "appsettings-schema.json",
  "SiteUrl": "http://localhost:3000",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "MemberImport": {
    "Secret": "iishf-import-2026"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Notifications": {
        "Email": "noreply@iishf.com",
        "Smtp": {
          "Host": "your-smtp-host",
          "Port": 587,
          "SecureSocketOptions": "StartTls",
          "Username": "your-smtp-username",
          "Password": "your-smtp-password"
        }
      },
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      }
    }
  }
}
